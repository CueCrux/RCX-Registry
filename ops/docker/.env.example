# Local docker-compose environment for RCX-Registry.
#
# Copy to `.env` and fill in the secrets. Never commit a populated `.env`.
# Production deploys should pull these from Vault / a secret manager
# instead of reading from disk.

# --- Postgres ---------------------------------------------------------
POSTGRES_USER=rcx_registry
POSTGRES_PASSWORD=change-me-do-not-ship-this
POSTGRES_DB=rcx_registry

# --- Server -----------------------------------------------------------
RCX_REGISTRY_SYNC_INTERVAL_SECS=3600
RCX_REGISTRY_MIN_INTERVAL_FLOOR_SECS=600
MCP_REGISTRY_BASE_URL=https://registry.modelcontextprotocol.io

# Master flag. Off in v1 staging until M9 launch gate.
FEATURE_RCX_REGISTRY=false
FEATURE_RCX_REGISTRY_PUBLISHER_DECLARATIONS=false
FEATURE_RCX_REGISTRY_ATTESTATIONS=false
FEATURE_RCX_REGISTRY_PROTOCOL_INTEGRATION=false
FEATURE_RCX_REGISTRY_SIGNED_CURSORS=false

# --- Receipt signer ---------------------------------------------------
RCX_REGISTRY_SIGNER_KID=vault:transit:rcx-registry-signing-key-1

# Vault Transit. Leave VAULT_ADDR blank for local dev (signer will emit
# zeroed signatures, which the server logs a warning about).
# Production: set both VAULT_ADDR and VAULT_TOKEN; key is provisioned in
# the same Vault Transit mount as the rest of CueCrux.
VAULT_ADDR=
VAULT_TOKEN=
VAULT_TRANSIT_KEY_NAME=rcx-registry-signing-key-1
VAULT_NAMESPACE=

# --- GitHub OAuth (M3 publisher rights) ------------------------------
# Provision a GitHub OAuth app at https://github.com/settings/applications/new.
# Authorization callback URL must match `/v0/publisher-rights/github/callback`
# on whichever host you serve from.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_SCOPE=read:user

# --- DNS resolver -----------------------------------------------------
# Default uses Cloudflare 1.1.1.1. Set to true to read /etc/resolv.conf
# instead — useful when running behind Tailscale MagicDNS.
RCX_REGISTRY_DNS_USE_SYSTEM_RESOLVER=false

# --- Logging ----------------------------------------------------------
RUST_LOG=info,rcx_registry_server=debug
