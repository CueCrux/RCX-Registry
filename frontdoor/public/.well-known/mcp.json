{
  "name": "org.rcxprotocol.registry",
  "description": "Verifiable, MCP-compatible subregistry mirroring the official MCP registry with signed CROWN receipts and publisher verification.",
  "version": "0.1.0",
  "homepage": "https://rcxprotocol.org",
  "transport": {
    "type": "http",
    "url": "https://registry.rcxprotocol.org"
  },
  "capabilities": {
    "registry": {
      "servers": "/v0/servers",
      "versions": "/v0/servers/{name}/versions",
      "openapi": "/openapi.json"
    }
  },
  "auth": {
    "read": "public",
    "publisher_rights": {
      "dns_txt": "/v0/publisher-rights/dns-challenge",
      "github_oauth": "/v0/publisher-rights/github/start"
    }
  },
  "receipts": {
    "signature": "ed25519",
    "hash": "blake3",
    "chained": true,
    "meta_namespace": "_meta.org.rcxprotocol.registry"
  }
}
